---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="A better way to browse Cannon's Auctions. Filter categories, search items, and get a mobile-friendly experience." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
