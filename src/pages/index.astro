---
import Base from '../layouts/Base.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const goonersScript = readFileSync(resolve('public/gooners.js'), 'utf-8');

// Categories to exclude by default
const excludeCategories = [
  'Coins', 'Currency', 'Jewelry', 'Watches',
  'Guns', 'Ammo', 'Firearms', 'Gemstones',
  'Sterling', 'silverplate',
];
---

<Base title="Gooners — Better Cannon's Auction Browsing">
  <h1>Gooners</h1>
  <p class="tagline">A better way to browse Cannon's Auctions. Search, filter, and actually enjoy mobile.</p>

  <h2>How It Works</h2>
  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-text">Edit your exclude list below (categories you don't want to see)</div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-text">Drag the bookmarklet to your bookmarks bar (or copy it on mobile)</div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-text">Visit a <a href="https://bid.cannonsauctions.com/Public/Auction/All" target="_blank" rel="noopener">Cannon's auction page</a> and click the bookmarklet</div>
    </div>
  </div>

  <h2>Exclude These Categories</h2>
  <p>Items matching these terms will be hidden. Click to remove, or type to add new ones.</p>

  <div class="cat-chips" id="exclude-chips">
    {excludeCategories.map(cat => (
      <button class="cat-chip excluded" data-label={cat}>{cat} &times;</button>
    ))}
  </div>
  <div style="margin-top:10px;display:flex;gap:8px;">
    <input type="text" id="add-exclude" class="add-input" placeholder="Add category term..." />
    <button id="add-btn" class="add-btn">Add</button>
  </div>

  <h2>Your Bookmarklet</h2>
  <div class="bookmarklet-area">
    <a id="bookmarklet" class="bookmarklet-link" href="#">
      Gooners
    </a>
    <p style="margin-top:12px;font-size:0.85rem;color:#888;">
      Drag this to your bookmarks bar
    </p>
    <button id="copy-btn" class="copy-btn">Copy to Clipboard</button>
  </div>

  <h2>Mobile Setup</h2>
  <div class="instructions">
    <details>
      <summary>iOS Safari</summary>
      <ol>
        <li>Tap <strong>Copy to Clipboard</strong> above</li>
        <li>Bookmark any page (tap Share &rarr; Add Bookmark)</li>
        <li>Go to Bookmarks, tap <strong>Edit</strong></li>
        <li>Find the bookmark you just made, tap it</li>
        <li>Clear the URL field and paste the copied code</li>
        <li>Save. Now visit a Cannon's auction and tap the bookmark.</li>
      </ol>
    </details>
    <details style="margin-top:8px;">
      <summary>Android Chrome</summary>
      <ol>
        <li>Tap <strong>Copy to Clipboard</strong> above</li>
        <li>Bookmark any page</li>
        <li>Open Bookmarks, long-press the bookmark &rarr; Edit</li>
        <li>Replace the URL with the copied code</li>
        <li>Save. Now visit a Cannon's auction and select the bookmark from the address bar.</li>
      </ol>
    </details>
  </div>

  <script define:vars={{ goonersScript }}>
    const chipsContainer = document.getElementById('exclude-chips');
    const bookmarkletLink = document.getElementById('bookmarklet');
    const copyBtn = document.getElementById('copy-btn');
    const addInput = document.getElementById('add-exclude');
    const addBtn = document.getElementById('add-btn');

    function getExcluded() {
      return Array.from(chipsContainer.querySelectorAll('.cat-chip'))
        .map(chip => chip.dataset.label);
    }

    function buildBookmarklet() {
      const config = JSON.stringify({ exclude: getExcluded() });
      const code = `javascript:(function(){window.__gooners_loaded=false;window.__gooners_config=${config};eval(${JSON.stringify(goonersScript)});})();`;
      bookmarkletLink.href = code;
      return code;
    }

    function addChip(label) {
      const btn = document.createElement('button');
      btn.className = 'cat-chip excluded';
      btn.dataset.label = label;
      btn.textContent = label + ' \u00d7';
      btn.addEventListener('click', () => { btn.remove(); buildBookmarklet(); });
      chipsContainer.appendChild(btn);
      buildBookmarklet();
    }

    // Wire up existing chips
    chipsContainer.querySelectorAll('.cat-chip').forEach(chip => {
      chip.addEventListener('click', () => { chip.remove(); buildBookmarklet(); });
    });

    // Add new exclude term
    function addFromInput() {
      const val = addInput.value.trim();
      if (val && !getExcluded().includes(val)) {
        addChip(val);
        addInput.value = '';
      }
    }
    addBtn.addEventListener('click', addFromInput);
    addInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') addFromInput();
    });

    // Copy button
    copyBtn.addEventListener('click', async () => {
      const code = buildBookmarklet();
      try {
        await navigator.clipboard.writeText(code);
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy to Clipboard'; }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = code;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy to Clipboard'; }, 2000);
      }
    });

    bookmarkletLink.addEventListener('click', (e) => { e.preventDefault(); });

    buildBookmarklet();
  </script>
</Base>
